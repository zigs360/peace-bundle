PORT=5000
JWT_SECRET=peace_bundle_secret_key_123
NODE_ENV=development
DATABASE_URL=postgres://postgres:password@127.0.0.1:5433/peacebundle

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# SMS Configuration (Termii)
SMS_PROVIDER=termii
SMS_API_KEY=your_termii_api_key
SMS_SECRET_KEY=your_termii_secret_key
SMS_SENDER_ID=PeaceBundle
SMS_BASE_URL=https://v3.api.termii.com

# PayVessel Configuration
PAYVESSEL_API_KEY=your_payvessel_api_key
PAYVESSEL_SECRET_KEY=your_payvessel_secret_key
PAYVESSEL_BUSINESS_ID=your_payvessel_business_id
PAYVESSEL_BASE_URL=https://api.payvessel.com/pms/api/external/request

# Smeplug Configuration
SMEPLUG_BASE_URL=https://smeplug.ng
SMEPLUG_SECRET_KEY=your_smeplug_secret_key
SMEPLUG_PUBLIC_KEY=your_smeplug_public_key
SMEPLUG_API_KEY=your_smeplug_api_key

# Ogdams Configuration
OGDAMS_API_KEY=your_ogdams_api_key
