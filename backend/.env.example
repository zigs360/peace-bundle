PORT=5000
JWT_SECRET=peace_bundle_secret_key_123
NODE_ENV=development
DATABASE_URL=postgres://postgres:password@127.0.0.1:5433/peacebundle

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM="Peace Bundlle" <no-reply@peacebundlle.com>
SMTP_ENCRYPTION=TLS

# SMS Configuration (Termii)
SMS_PROVIDER=termii
SMS_API_KEY=your_termii_api_key
SMS_SECRET_KEY=your_termii_secret_key
SMS_SENDER_ID=PeaceBundle
SMS_BASE_URL=https://v3.api.termii.com

# Frontend Origins (comma separated, production)
FRONTEND_URL=https://www.peacebundlle.com
FRONTEND_URLS=https://www.peacebundlle.com

# Mock BVN Controls (production safety)
MOCK_BVN_ALLOWED=false
MOCK_BVN_FUNDING_CAP_NGN=50000
MOCK_BVN_MAX_EVENTS_24H=3

# PayVessel Configuration
PAYVESSEL_API_KEY=your_payvessel_api_key
PAYVESSEL_SECRET_KEY=your_payvessel_secret_key
PAYVESSEL_BUSINESS_ID=your_payvessel_business_id
PAYVESSEL_BASE_URL=https://api.payvessel.com/pms/api/external/request

# Smeplug Configuration
SMEPLUG_BASE_URL=https://smeplug.ng
SMEPLUG_SECRET_KEY=your_smeplug_secret_key
SMEPLUG_PUBLIC_KEY=your_smeplug_public_key
SMEPLUG_API_KEY=your_smeplug_api_key

# Ogdams Configuration
OGDAMS_BASE_URL=https://simhosting.ogdams.ng/api/v1
OGDAMS_API_KEY=your_ogdams_api_key
OGDAMS_AUTH_STYLE=bearer
OGDAMS_TIMEOUT_MS=12000
OGDAMS_AIRTIME_PATH=/vend/airtime
OGDAMS_STATUS_PATH=/transactions
OGDAMS_STATUS_CHECK_ENABLED=true
OGDAMS_HEALTH_URL=
OGDAMS_HEALTH_TIMEOUT_MS=2500
OGDAMS_HEALTH_MONITOR_INTERVAL_MS=30000
OGDAMS_FAILOVER_OPEN_MS=300000
OGDAMS_BALANCE_FAILOVER_OPEN_MS=600000
OGDAMS_FAILOVER_ALERT_COOLDOWN_MS=600000

# Airtime routing and reconciliation
AIRTIME_PRIMARY_ROUTE=ogdams
AIRTIME_OGDAMS_FALLBACK_TO_SMEPLUG=true
AIRTIME_MAX_NGN=100000
AIRTIME_RECONCILE_DELAY_MS=5000
AIRTIME_RECONCILE_MAX_ATTEMPTS=3
AIRTIME_RECONCILE_JOB_ENABLED=true

# BillStack Configuration
BILLSTACK_BASE_URL=https://api.billstack.co/v2/thirdparty
BILLSTACK_SECRET_KEY=your_billstack_secret_key
BILLSTACK_PUBLIC_KEY=your_billstack_public_key
BILLSTACK_WEBHOOK_SECRET=your_billstack_webhook_secret
BILLSTACK_BANK=PALMPAY

# Safe Haven Configuration
SAFEHAVEN_BASE_URL=https://api.safehavenmfb.com
SAFEHAVEN_ACCESS_TOKEN=your_safehaven_access_token
SAFEHAVEN_CLIENT_ID=your_safehaven_client_id
SAFEHAVEN_CREATE_ACCOUNT_PATH=/accounts/v2/subaccount
SAFEHAVEN_TIMEOUT_MS=30000

# Virtual account fallback order for secondary workflows
VA_SECONDARY_WORKFLOWS=safehaven,9psb

# Virtual account router configuration
VA_ROUTER_PRIORITY=PALMPAY,PROVIDUS,SAFEHAVEN,9PSB
VA_ROUTER_HEALTH_TTL_MS=10000
VA_ROUTER_BREAKER_THRESHOLD=3
VA_ROUTER_BREAKER_WINDOW_MS=120000
VA_ROUTER_BREAKER_OPEN_MS=300000

# Optional provider health URLs (used for routing decisions)
BILLSTACK_HEALTH_URL=
PAYVESSEL_HEALTH_URL=
SAFEHAVEN_HEALTH_URL=
